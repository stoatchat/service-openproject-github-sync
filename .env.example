# GitHub Personal Access Token
GH_TOKEN=

# OpenProject API Token
OP_TOKEN=

# OpenProject instance URL
OP_URL=https://op.stoatinternal.com

# Secret token for webhook authentication
SECRET_TOKEN=

# Repository to Project mapping (comma-separated: owner/repo:project_id)
# Example: stoatchat/for-web:8,stoatchat/another-repo:99
REPO_PROJECT_MAP=stoatchat/for-web:8

# Assignee mapping (optional, comma-separated: github_user:op_user_id)
# Example: johndoe:42,janedoe:123
ASSIGNEE_MAP=

# OpenProject custom field ID for "GitHub Issue" field
# This is the custom field that stores the GitHub issue number
OP_GITHUB_ISSUE_FIELD=customField123
